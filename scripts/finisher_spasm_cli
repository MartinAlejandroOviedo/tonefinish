if [[ "$METHOD" == "adapt_preset_to_audio" ]]; then
  python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
preset = a[0] if len(a)>0 and isinstance(a[0],dict) else (kw.get("preset",{}) if isinstance(kw.get("preset",{}),dict) else {})
chars = a[1] if len(a)>1 and isinstance(a[1],dict) else (kw.get("characteristics",{}) if isinstance(kw.get("characteristics",{}),dict) else {})
out=dict(preset)

band_stats = chars.get("band_stats",{}) if isinstance(chars.get("band_stats",{}),dict) else {}
voice_rms = chars.get("voice_rms")
loud = chars.get("loudness",{}) if isinstance(chars.get("loudness",{}),dict) else chars.get("loudness_metrics",{}) if isinstance(chars.get("loudness_metrics",{}),dict) else {}
input_lra = float(loud.get("input_lra",0.0) or 0.0)
input_tp = float((chars.get("clipping_info",{}) if isinstance(chars.get("clipping_info",{}),dict) else {}).get("input_tp",-99.0) or -99.0)

# Defaults robustos
out.setdefault("dynamic_eq", False)
out.setdefault("stereo_width", True)
out.setdefault("deesser", False)
out.setdefault("saturation_enabled", False)
out.setdefault("saturation_per_band", False)
out.setdefault("glue_enabled", False)
out.setdefault("autogain_enabled", True)
out.setdefault("autogain_maxgain", 1.35)
out.setdefault("headroom_db", -17.0)
out.setdefault("tone_low_db", 0.0)
out.setdefault("sub_bass_db", 0.0)
out.setdefault("tone_mid_db", 0.0)
out.setdefault("tone_high_db", 0.0)
out.setdefault("tone_tilt_db", 0.0)
out.setdefault("saturation_drive_db", 0.0)
out.setdefault("saturation_mix", 0.0)
out.setdefault("glue_ratio", 1.4)
out.setdefault("glue_threshold_db", -18.0)
out.setdefault("glue_attack_ms", 20.0)
out.setdefault("glue_release_ms", 120.0)

# Heurísticas de adaptación
if input_lra > 6.0:
    out["dynamic_eq"] = True
    out["glue_enabled"] = bool(input_lra > 7.5)
    out["autogain_enabled"] = True
    out["autogain_maxgain"] = min(1.6, float(out.get("autogain_maxgain",1.35) or 1.35))
elif input_lra < 4.0:
    out["glue_enabled"] = False
    out["autogain_enabled"] = False
    out["autogain_maxgain"] = min(1.25, float(out.get("autogain_maxgain",1.35) or 1.35))
else:
    out["glue_enabled"] = False
    out["autogain_enabled"] = False
    out["autogain_maxgain"] = min(1.4, float(out.get("autogain_maxgain",1.35) or 1.35))

hm = float(band_stats.get("High-Mid (2k-6k Hz)", -99.0) or -99.0)
air = float(band_stats.get("Air (6k-16k Hz)", -99.0) or -99.0)
if (voice_rms is not None and float(voice_rms) > -35.0) or hm > -22.0:
    out["deesser"] = True
if hm < -28.0 and air < -31.0:
    out["tone_high_db"] = min(2.0, float(out.get("tone_high_db",0.0) or 0.0) + 0.8)

if input_tp < -8.0 and input_lra >= 6.0:
    out["saturation_enabled"] = True
    out["saturation_mix"] = max(0.08, float(out.get("saturation_mix",0.0) or 0.0))
    out["saturation_mix"] = min(0.15, float(out.get("saturation_mix",0.0) or 0.0))
    out["saturation_drive_db"] = max(0.8, float(out.get("saturation_drive_db",0.0) or 0.0))
    out["saturation_drive_db"] = min(1.5, float(out.get("saturation_drive_db",0.0) or 0.0))
else:
    out["saturation_enabled"] = False
    out["saturation_mix"] = min(0.08, float(out.get("saturation_mix",0.0) or 0.0))

print(json.dumps({"ok": True, "result": out}, ensure_ascii=False))
PY
  exit $?
fi

if [[ "$METHOD" == "analyze_batch_for_automaster" ]]; then
  META="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
files=a[0] if len(a)>0 else kw.get("files",[])
target_lufs=float(a[1] if len(a)>1 else kw.get("target_lufs",-14.0))
true_peak=float(a[2] if len(a)>2 else kw.get("true_peak",-1.0))
norm=[]
for f in (files if isinstance(files,list) else []):
    if isinstance(f,dict) and f.get("__type__")=="path":
        norm.append(str(f.get("value","")))
    else:
        norm.append(str(f))
print(json.dumps({"files":norm,"target_lufs":target_lufs,"true_peak":true_peak}, ensure_ascii=False))
PY
)"

  python3 - <<'PY' "$META" "$0"
import json,sys,subprocess,os
meta=json.loads(sys.argv[1]); cli=sys.argv[2]
files=meta.get("files",[])
target=float(meta.get("target_lufs",-14.0))
tp=float(meta.get("true_peak",-1.0))

individual={}
char_list=[]
reco_list=[]

for p in files:
    req={
      "method":"analyze_audio_for_automaster",
      "args":[{"__type__":"path","value":p},target,tp],
      "kwargs":{}
    }
    proc=subprocess.run([cli,"call","--json"],input=json.dumps(req),text=True,capture_output=True)
    if proc.returncode!=0:
      continue
    try:
      out=json.loads(proc.stdout or "{}")
    except Exception:
      continue
    if not out.get("ok"):
      continue
    result=out.get("result",{})
    vals=result.get("value",[]) if isinstance(result,dict) else []
    if len(vals)<3:
      continue
    chars,reco,spec=vals[0],vals[1],vals[2]
    individual[p]={"characteristics":chars,"recommendation":reco,"spec":spec}
    if isinstance(chars,dict): char_list.append(chars)
    if isinstance(reco,dict): reco_list.append(reco)

if not individual:
    print(json.dumps({"ok": False, "error":"no se pudo analizar ningún archivo del lote"}, ensure_ascii=False))
    raise SystemExit(1)

# Merge simple
merged={"band_stats":{}, "voice_rms": None, "loudness_metrics":{}}
voice_vals=[]
li=[]; lra=[]; tp_vals=[]
acc={}
count={}
for c in char_list:
    bs=c.get("band_stats",{}) if isinstance(c.get("band_stats",{}),dict) else {}
    for k,v in bs.items():
      try:
        fv=float(v)
      except Exception:
        continue
      acc[k]=acc.get(k,0.0)+fv
      count[k]=count.get(k,0)+1
    vr=c.get("voice_rms")
    if isinstance(vr,(int,float)): voice_vals.append(float(vr))
    loud=c.get("loudness",{}) if isinstance(c.get("loudness",{}),dict) else {}
    if isinstance(loud.get("input_i"),(int,float)): li.append(float(loud["input_i"]))
    if isinstance(loud.get("input_lra"),(int,float)): lra.append(float(loud["input_lra"]))
    clip=c.get("clipping_info",{}) if isinstance(c.get("clipping_info",{}),dict) else {}
    if isinstance(clip.get("input_tp"),(int,float)): tp_vals.append(float(clip["input_tp"]))
for k,s in acc.items():
    merged["band_stats"][k]=s/max(1,count.get(k,1))
if voice_vals:
    merged["voice_rms"]=sum(voice_vals)/len(voice_vals)
merged["loudness_metrics"]={
  "input_i": (sum(li)/len(li)) if li else None,
  "input_lra": (sum(lra)/len(lra)) if lra else None,
  "input_tp": max(tp_vals) if tp_vals else None,
}

# Reco consolidada por mayoría
def maj(key, default=False):
    vals=[bool(r.get(key,default)) for r in reco_list if isinstance(r,dict)]
    if not vals: return bool(default)
    return sum(1 for v in vals if v) >= (len(vals)/2.0)
reco={
  "dynamic_eq": maj("dynamic_eq", False),
  "stereo_width": maj("stereo_width", True),
  "deesser": maj("deesser", False),
  "saturation_enabled": maj("saturation_enabled", False),
  "glue_enabled": maj("glue_enabled", False),
}

print(json.dumps({"ok": True, "result": {"__type__":"tuple","value":[merged,reco,individual]}}, ensure_ascii=False))
PY
  exit $?
fi

if [[ "$METHOD" == "update_saturation_budgets_for_batch" ]]; then
  python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
batch = a[0] if len(a)>0 and isinstance(a[0],dict) else (kw.get("batch_data",{}) if isinstance(kw.get("batch_data",{}),dict) else {})

# Extraer nivel relativo de riesgo por archivo
entries=[]
for k,v in batch.items():
    if not isinstance(v,dict):
        continue
    chars=v.get("characteristics",{}) if isinstance(v.get("characteristics",{}),dict) else {}
    loud=chars.get("loudness",{}) if isinstance(chars.get("loudness",{}),dict) else chars.get("loudness_metrics",{}) if isinstance(chars.get("loudness_metrics",{}),dict) else {}
    clip=chars.get("clipping_info",{}) if isinstance(chars.get("clipping_info",{}),dict) else {}
    lra=float(loud.get("input_lra",0.0) or 0.0)
    tp=float(clip.get("input_tp",-99.0) or -99.0)
    risk=0.0
    if tp > -3.0: risk += 1.0
    if tp > -2.0: risk += 1.0
    if lra < 4.0: risk += 0.8
    if lra > 7.5: risk -= 0.3
    entries.append((k,risk))

# Ordenar por riesgo y asignar budget de saturación
entries.sort(key=lambda x: x[1], reverse=True)
out={}
n=max(1,len(entries))
for i,(k,risk) in enumerate(entries):
    base=batch.get(k,{}) if isinstance(batch.get(k,{}),dict) else {}
    nv=dict(base)
    reco=nv.get("recommendation",{}) if isinstance(nv.get("recommendation",{}),dict) else {}
    # más riesgo => menos saturación
    rank=i/(n-1) if n>1 else 0.0
    mix=max(0.15, 0.40 - 0.20*rank - 0.05*max(0.0,risk))
    drive=max(1.0, 2.4 - 1.0*rank - 0.3*max(0.0,risk))
    reco["saturation_enabled"]=bool(reco.get("saturation_enabled", False))
    reco["saturation_mix"]=round(mix,3)
    reco["saturation_drive_db"]=round(drive,3)
    nv["recommendation"]=reco
    nv["saturation_budget"]={
      "risk": round(risk,3),
      "rank": round(rank,3),
      "mix": round(mix,3),
      "drive_db": round(drive,3),
    }
    out[k]=nv

print(json.dumps({"ok": True, "result": out}, ensure_ascii=False))
PY
  exit $?
fi

if [[ "$METHOD" == "health" ]]; then
  CORE_OUT="$(printf '%s\n' "$METHOD" | "$SPASM_BIN" "$CORE_SCRIPT" 2>/dev/null || true)"
  STATUS="$(printf '%s\n' "$CORE_OUT" | sed -n '1p')"
  VALUE="$(printf '%s\n' "$CORE_OUT" | sed -n '2p')"
  if [[ "$STATUS" == "OK" ]]; then
    python3 -c 'import json,sys; v=sys.argv[1]; print(json.dumps({"ok": True, "result": v}, ensure_ascii=False))' "$VALUE"
    exit 0
  fi
fi

python3 -c 'import json,sys; m=sys.argv[1]; print(json.dumps({"ok": False, "error": f"método no implementado aún en SpASM CLI: {m}"}, ensure_ascii=False))' "$METHOD"
exit 1
