#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SPASM_BIN="${FINISHER_SPASM_BIN:-}"
if [[ -z "$SPASM_BIN" ]]; then
  if command -v spasm >/dev/null 2>&1; then
    SPASM_BIN="$(command -v spasm)"
  elif [[ -x /usr/bin/spasm ]]; then
    SPASM_BIN=/usr/bin/spasm
  elif [[ -x /usr/local/bin/spasm ]]; then
    SPASM_BIN=/usr/local/bin/spasm
  elif [[ -x /home/martin/Documentos/SpASM/spasm ]]; then
    # Compatibilidad exclusiva con el árbol de desarrollo local.
    SPASM_BIN=/home/martin/Documentos/SpASM/spasm
  else
    echo '{"ok": false, "error": "runtime SpASM no encontrado; instale el paquete spasm o configure FINISHER_SPASM_BIN"}'
    exit 1
  fi
fi
# Los skills auxiliares de SpASM (incluido ffmpeg-spasm) consumen SPASM_BIN.
# Exportarlo evita que cada subproceso vuelva al default inválido /usr/bin/spasm.
export SPASM_BIN
CORE_SCRIPT="$ROOT_DIR/spasm_cli/finisher_cli_core.spasm"
FFMPEG_BIN="${FINISHER_FFMPEG_BIN:-}"
if [[ -z "$FFMPEG_BIN" ]]; then
  if command -v ffmpeg-spasm >/dev/null 2>&1; then
    FFMPEG_BIN="$(command -v ffmpeg-spasm)"
  else
    FFMPEG_BIN="ffmpeg"
  fi
fi
if [[ "$FFMPEG_BIN" == *"/ffmpeg.real-spasm-backup" || "$FFMPEG_BIN" == "ffmpeg.real-spasm-backup" ]]; then
  if command -v ffmpeg-spasm >/dev/null 2>&1; then
    FFMPEG_BIN="$(command -v ffmpeg-spasm)"
  else
    FFMPEG_BIN="/usr/bin/ffmpeg"
  fi
fi
FFPROBE_BIN="${FINISHER_FFPROBE_BIN:-}"
if [[ -z "$FFPROBE_BIN" ]]; then
  if [[ "$(basename "$FFMPEG_BIN")" == "ffmpeg" ]]; then
    ffmpeg_dir="$(dirname "$FFMPEG_BIN")"
    if [[ -z "$ffmpeg_dir" || "$ffmpeg_dir" == "." ]]; then
      FFPROBE_BIN="ffprobe"
    else
      FFPROBE_BIN="${ffmpeg_dir}/ffprobe"
    fi
  else
    FFPROBE_BIN="ffprobe"
  fi
fi

if [[ "${1:-}" != "call" || "${2:-}" != "--json" ]]; then
  echo '{"ok": false, "error": "uso: finisher_spasm_cli call --json"}'
  exit 2
fi

REQ="$(cat)"
if [[ -z "${REQ// }" ]]; then
  echo '{"ok": false, "error": "stdin vacío"}'
  exit 1
fi

_spasm_err_reported=0
_spasm_json_error() {
  local msg="${1:-error_no_especificado}"
  _spasm_err_reported=1
  python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": sys.argv[1]}, ensure_ascii=False))' "$msg"
}
_spasm_err_trap() {
  local ec=$?
  if [[ "$ec" -ne 0 && "$_spasm_err_reported" -eq 0 ]]; then
    _spasm_json_error "cli_unhandled_error(method=${METHOD:-unknown},line=${BASH_LINENO[0]:-0},code=${ec})"
  fi
  exit "$ec"
}
trap _spasm_err_trap ERR

METHOD="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("method",""))' <<<"$REQ" 2>/dev/null || true)"
if [[ -z "$METHOD" ]]; then
  echo '{"ok": false, "error": "request JSON inválido o sin method"}'
  exit 1
fi

USER_STATE_BASE="${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}"
DEFAULT_SPASM_STATE_BASE="${USER_STATE_BASE}/tonefinish/spasm"
JOB_DIR="${FINISHER_SPASM_JOB_DIR:-$DEFAULT_SPASM_STATE_BASE/jobs}"
RUNNER="$ROOT_DIR/scripts/spasm_batch_job_runner.py"
STATE_DIR="${FINISHER_SPASM_STATE_DIR:-$DEFAULT_SPASM_STATE_BASE/state}"
mkdir -p "$STATE_DIR" "$JOB_DIR"
AUDIO_ACTIVE_FILE="$STATE_DIR/audio_active.count"
LOW_ACTIVE_FILE="$STATE_DIR/low_active.count"

_audio_active_count() {
  python3 - <<'PY' "$AUDIO_ACTIVE_FILE"
import os,sys
path=sys.argv[1]
try:
    with open(path,"r",encoding="utf-8") as fh:
        print(max(0,int((fh.read() or "0").strip())))
except Exception:
    print(0)
PY
}

_audio_count_update() {
  python3 - <<'PY' "$AUDIO_ACTIVE_FILE" "$1"
import os,sys,fcntl
path,delta=sys.argv[1],int(sys.argv[2])
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path,"a+",encoding="utf-8") as fh:
    fcntl.flock(fh.fileno(), fcntl.LOCK_EX)
    fh.seek(0)
    raw=(fh.read() or "0").strip()
    cur=int(raw) if raw else 0
    nxt=max(0,cur+delta)
    fh.seek(0); fh.truncate(0); fh.write(str(nxt)); fh.flush()
    fcntl.flock(fh.fileno(), fcntl.LOCK_UN)
print(nxt)
PY
}

_counter_read() {
  python3 - <<'PY' "$1"
import sys
path=sys.argv[1]
try:
    with open(path,"r",encoding="utf-8") as fh:
        print(max(0,int((fh.read() or "0").strip())))
except Exception:
    print(0)
PY
}

_counter_update() {
  python3 - <<'PY' "$1" "$2"
import os,sys,fcntl
path,delta=sys.argv[1],int(sys.argv[2])
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path,"a+",encoding="utf-8") as fh:
    fcntl.flock(fh.fileno(), fcntl.LOCK_EX)
    fh.seek(0)
    raw=(fh.read() or "0").strip()
    cur=int(raw) if raw else 0
    nxt=max(0,cur+delta)
    fh.seek(0); fh.truncate(0); fh.write(str(nxt)); fh.flush()
    fcntl.flock(fh.fileno(), fcntl.LOCK_UN)
print(nxt)
PY
}

_method_is_audio_priority() {
  case "$1" in
    normalize_audio|apply_output_gain|analyze_audio|analyze_audio_with_filter|build_preprocess_chain|analyze_eq_bands|analyze_voice_band)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

_method_is_low_priority() {
  case "$1" in
    get_runtime_resource_info|get_processing_limits|batch_status|get_audio_info|fix_audio_tools)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

_wait_if_audio_busy_for_low_priority() {
  local timeout_ms="${FINISHER_SPASM_LOWPRIO_WAIT_MS:-2500}"
  local step_ms=100
  local waited=0
  while true; do
    local active
    active="$(_audio_active_count)"
    if [[ "${active:-0}" -le 0 ]]; then
      break
    fi
    if [[ "$waited" -ge "$timeout_ms" ]]; then
      break
    fi
    sleep 0.1
    waited=$((waited + step_ms))
  done
}

_acquire_low_slot() {
  local max_low="${FINISHER_SPASM_MAX_LOWPRIO_INFLIGHT:-1}"
  local timeout_ms="${FINISHER_SPASM_LOWPRIO_SLOT_WAIT_MS:-5000}"
  local step_ms=100
  local waited=0
  while true; do
    local active_low
    active_low="$(_counter_read "$LOW_ACTIVE_FILE")"
    if [[ "${active_low:-0}" -lt "$max_low" ]]; then
      _counter_update "$LOW_ACTIVE_FILE" 1 >/dev/null
      # Revalidar para evitar carrera: si nos pasamos, devolvemos y esperamos.
      active_low="$(_counter_read "$LOW_ACTIVE_FILE")"
      if [[ "${active_low:-0}" -le "$max_low" ]]; then
        return 0
      fi
      _counter_update "$LOW_ACTIVE_FILE" -1 >/dev/null
    fi
    if [[ "$waited" -ge "$timeout_ms" ]]; then
      # Degradar a best-effort: no bloquear indefinidamente.
      return 0
    fi
    sleep 0.1
    waited=$((waited + step_ms))
  done
}

if _method_is_audio_priority "$METHOD"; then
  _audio_count_update 1 >/dev/null
  trap '_audio_count_update -1 >/dev/null' EXIT
elif _method_is_low_priority "$METHOD"; then
  _wait_if_audio_busy_for_low_priority
  _acquire_low_slot
  trap '_counter_update "$LOW_ACTIVE_FILE" -1 >/dev/null' EXIT
fi

if [[ "$METHOD" == "batch_start" ]]; then
  JOB_ID="job_$(date +%s)_$RANDOM"
  mkdir -p "$JOB_DIR"
  PAYLOAD_PATH="$JOB_DIR/${JOB_ID}.payload.json"
  STATUS_PATH="$JOB_DIR/${JOB_ID}.status.json"
  python3 - <<'PY' "$REQ" "$PAYLOAD_PATH"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[])
payload = a[0] if a and isinstance(a[0], dict) else {}
with open(sys.argv[2], "w", encoding="utf-8") as fh:
    json.dump(payload, fh, ensure_ascii=False, indent=2)
PY
  python3 - <<'PY' "$JOB_ID" "$STATUS_PATH"
import json,sys,time
job_id=sys.argv[1]
status_path=sys.argv[2]
queued_at=time.time()
status={
  "job_id": job_id,
  "state": "queued",
  "progress": 0.0,
  "message": "En cola",
  "current": 0,
  "total": 0,
  "queued_at": queued_at,
  "started_at": None,
  "queue_wait_ms": None,
  "updated_at": queued_at,
  "result_message": None,
  "results": None,
  "error": None,
}
with open(status_path,"w",encoding="utf-8") as fh:
    json.dump(status, fh, ensure_ascii=False, indent=2)
PY
  (
    nohup python3 "$RUNNER" "$JOB_ID" "$PAYLOAD_PATH" "$STATUS_PATH" >/dev/null 2>&1 &
  )
  python3 - <<'PY' "$JOB_ID"
import json,sys
print(json.dumps({"ok": True, "result": {"job_id": sys.argv[1]}}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "batch_status" ]]; then
  JOB_ID="$(python3 -c 'import json,sys; d=json.load(sys.stdin); a=d.get("args",[]); print(a[0] if a else "")' <<<"$REQ" 2>/dev/null || true)"
  if [[ -z "$JOB_ID" ]]; then
    echo '{"ok": false, "error": "batch_status requiere job_id"}'
    exit 1
  fi
  STATUS_PATH="$JOB_DIR/${JOB_ID}.status.json"
  if [[ ! -f "$STATUS_PATH" ]]; then
    PAYLOAD_PATH="$JOB_DIR/${JOB_ID}.payload.json"
    if [[ -f "$PAYLOAD_PATH" ]]; then
      python3 - <<'PY' "$JOB_ID"
import json,sys,time
print(json.dumps({
  "ok": True,
  "result": {
    "job_id": sys.argv[1],
    "state": "queued",
    "progress": 0.0,
    "message": "En cola",
    "current": 0,
    "total": 0,
    "updated_at": time.time(),
  }
}, ensure_ascii=False))
PY
      exit 0
    fi
    echo '{"ok": false, "error": "job no encontrado"}'
    exit 1
  fi
  python3 - <<'PY' "$STATUS_PATH"
import json,sys,time
with open(sys.argv[1], "r", encoding="utf-8") as fh:
    status = json.load(fh)
now=time.time()
updated_at=status.get("updated_at")
if isinstance(updated_at,(int,float)):
    status["status_age_ms"]=max(0,int((now-float(updated_at))*1000))
else:
    status["status_age_ms"]=None
if status.get("queue_wait_ms") is None:
    q=status.get("queued_at")
    s=status.get("started_at")
    if isinstance(q,(int,float)) and isinstance(s,(int,float)):
        status["queue_wait_ms"]=max(0,int((float(s)-float(q))*1000))
print(json.dumps({"ok": True, "result": status}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "batch_cancel" ]]; then
  JOB_ID="$(python3 -c 'import json,sys; d=json.load(sys.stdin); a=d.get("args",[]); print(a[0] if a else "")' <<<"$REQ" 2>/dev/null || true)"
  if [[ -z "$JOB_ID" ]]; then
    echo '{"ok": false, "error": "batch_cancel requiere job_id"}'
    exit 1
  fi
  mkdir -p "$JOB_DIR"
  CANCEL_PATH="$JOB_DIR/${JOB_ID}.status.cancel"
  touch "$CANCEL_PATH"
  python3 - <<'PY'
import json
print(json.dumps({"ok": True, "result": True}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "get_runtime_resource_info" ]]; then
  python3 - <<'PY'
import json
from resource_monitor import ResourceMonitor

monitor = ResourceMonitor()
snapshot = monitor.snapshot()
gpu_snapshot = monitor.gpu_snapshot()

gpu_info = {"available": gpu_snapshot is not None}
if gpu_snapshot is not None:
    gpu_info.update(
        {
            "backend": gpu_snapshot.backend,
            "device_count": gpu_snapshot.device_count,
            "name": gpu_snapshot.name,
            "driver_version": gpu_snapshot.driver_version,
            "utilization_percent": gpu_snapshot.utilization_percent,
            "memory_total_mb": gpu_snapshot.memory_total_mb,
            "memory_used_mb": gpu_snapshot.memory_used_mb,
            "memory_free_mb": gpu_snapshot.memory_free_mb,
        }
    )
else:
    gpu_info.update(
        {
            "backend": "none",
            "device_count": 0,
            "name": None,
            "driver_version": None,
            "utilization_percent": None,
            "memory_total_mb": None,
            "memory_used_mb": None,
            "memory_free_mb": None,
        }
    )

result = {
    "summary": snapshot.format_summary(),
    "cpu": {
        "cpu_count": snapshot.cpu_count,
        "cpu_percent": snapshot.cpu_percent,
        "memory_percent": snapshot.memory_percent,
        "memory_available_gb": snapshot.memory_available_gb,
        "ffmpeg_processes": snapshot.ffmpeg_processes,
    },
    "gpu": gpu_info,
}
print(json.dumps({"ok": True, "result": result}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "ensure_ffmpeg_available" ]]; then
  python3 - <<'PY'
import json
from audio_tools import ensure_ffmpeg_available
ensure_ffmpeg_available()
print(json.dumps({"ok": True, "result": True}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "get_processing_limits" ]]; then
  python3 - <<'PY'
import json
from audio_tools import get_processing_limits
print(json.dumps({"ok": True, "result": get_processing_limits()}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "get_audio_info" ]]; then
  python3 - <<'PY' "$REQ"
import json,sys
from audio_tools import get_audio_info
d=json.loads(sys.argv[1]); a=d.get("args",[])
input_path=str(a[0]) if len(a)>0 else ""
use_cache=bool(a[1]) if len(a)>1 else True
print(json.dumps({"ok": True, "result": get_audio_info(input_path, use_cache=use_cache)}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "extract_loudnorm_stats" ]]; then
  python3 - <<'PY' "$REQ"
import json,sys
from audio_tools import extract_loudnorm_stats
d=json.loads(sys.argv[1]); a=d.get("args",[])
output=str(a[0]) if len(a)>0 else ""
print(json.dumps({"ok": True, "result": extract_loudnorm_stats(output)}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "cancel_running_ffmpeg_processes" ]]; then
  python3 - <<'PY'
import json
from audio_tools import cancel_running_ffmpeg_processes
print(json.dumps({"ok": True, "result": int(cancel_running_ffmpeg_processes())}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "fix_audio_tools" ]]; then
  python3 - <<'PY' "$REQ" "$ROOT_DIR"
import json,sys,pathlib
from fix_audio_tools import apply_fixes
d=json.loads(sys.argv[1]); a=d.get("args",[])
root=pathlib.Path(sys.argv[2])
target = pathlib.Path(a[0]) if len(a)>0 and a[0] else (root / "audio_tools.py")
dry_run = bool(a[1]) if len(a)>1 else False
res = apply_fixes(target=target, dry_run=dry_run)
print(json.dumps({"ok": True, "result": res}, ensure_ascii=False))
PY
  exit 0
fi

if [[ "$METHOD" == "ensure_output_path" ]]; then
  BASE="$(python3 -c 'import json,sys; d=json.load(sys.stdin); a=d.get("args",[]); p=(a[0].get("value") if isinstance(a[0],dict) and a[0].get("__type__")=="path" else a[0]) if len(a)>0 else ""; print(p)' <<<"$REQ")"
  FMT="$(python3 -c 'import json,sys; d=json.load(sys.stdin); a=d.get("args",[]); print(a[1] if len(a)>1 else "")' <<<"$REQ")"

  CORE_OUT="$(printf '%s\n%s\n%s\n' "$METHOD" "$BASE" "$FMT" | "$SPASM_BIN" "$CORE_SCRIPT" 2>/dev/null || true)"
  STATUS="$(printf '%s\n' "$CORE_OUT" | sed -n '1p')"
  BASE_OUT="$(printf '%s\n' "$CORE_OUT" | sed -n '2p')"
  EXT_OUT="$(printf '%s\n' "$CORE_OUT" | sed -n '3p')"
  APPEND_FLAG="$(printf '%s\n' "$CORE_OUT" | sed -n '4p')"

  if [[ "$STATUS" == "OK" ]]; then
    VALUE="$BASE_OUT"
    if [[ "$APPEND_FLAG" == "1" ]]; then
      VALUE="${BASE_OUT}${EXT_OUT}"
    fi
    python3 -c 'import json,sys; v=sys.argv[1]; print(json.dumps({"ok": True, "result": {"__type__":"path","value": v}}, ensure_ascii=False))' "$VALUE"
    exit 0
  fi

  python3 -c 'import json,sys; e=sys.argv[1] or "error_spasm_core"; print(json.dumps({"ok": False, "error": e}, ensure_ascii=False))' "$BASE_OUT"
  exit 1
fi

if [[ "$METHOD" == "resolve_repair_levels" ]]; then
  PAYLOAD="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[])
stats=a[0] if len(a)>0 else None
noise=a[1] if len(a)>1 else "Off"
declip=a[2] if len(a)>2 else "Off"
declick=a[3] if len(a)>3 else "Off"
has_stats=1 if isinstance(stats,dict) else 0
input_tp=0.0; input_thresh=-50.0
if isinstance(stats,dict):
    input_tp=float(stats.get("input_tp",0.0) or 0.0)
    input_thresh=float(stats.get("input_thresh",-50.0) or -50.0)
print(noise); print(declip); print(declick); print(has_stats); print(int(round(input_tp*100.0))); print(int(round(input_thresh*100.0)))
PY
)"
  CORE_OUT="$(printf '%s\n%s\n' "$METHOD" "$PAYLOAD" | "$SPASM_BIN" "$CORE_SCRIPT" 2>/dev/null || true)"
  STATUS="$(printf '%s\n' "$CORE_OUT" | sed -n '1p')"
  N="$(printf '%s\n' "$CORE_OUT" | sed -n '2p')"
  DCL="$(printf '%s\n' "$CORE_OUT" | sed -n '3p')"
  DCK="$(printf '%s\n' "$CORE_OUT" | sed -n '4p')"
  if [[ "$STATUS" == "OK" ]]; then
    python3 -c 'import json,sys; print(json.dumps({"ok": True, "result": [sys.argv[1],sys.argv[2],sys.argv[3]]}, ensure_ascii=False))' "$N" "$DCL" "$DCK"
    exit 0
  fi
  python3 -c 'import json; print(json.dumps({"ok": False, "error":"error_spasm_core_resolve_repair_levels"}, ensure_ascii=False))'
  exit 1
fi

if [[ "$METHOD" == "evaluate_mix" ]]; then
  PAYLOAD="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[])
stats=a[0] if len(a)>0 and isinstance(a[0],dict) else {}
target=float(a[1] if len(a)>1 else -14.0)
tp=float(a[2] if len(a)>2 else -1.0)
ii=float(stats.get("input_i",0.0) or 0.0)
itp=float(stats.get("input_tp",0.0) or 0.0)
ilra=float(stats.get("input_lra",0.0) or 0.0)
off=float(stats.get("target_offset",0.0) or 0.0)
vals=[ii,itp,ilra,off,target,tp]
for v in vals: print(int(round(v*100.0)))
PY
)"
  CORE_OUT="$(printf '%s\n%s\n' "$METHOD" "$PAYLOAD" | "$SPASM_BIN" "$CORE_SCRIPT" 2>/dev/null || true)"
  STATUS="$(printf '%s\n' "$CORE_OUT" | sed -n '1p')"
  RATING="$(printf '%s\n' "$CORE_OUT" | sed -n '2p')"
  ADVICE="$(printf '%s\n' "$CORE_OUT" | sed -n '3p')"
  if [[ "$STATUS" == "OK" ]]; then
    python3 -c 'import json,sys; print(json.dumps({"ok": True, "result": [sys.argv[1],sys.argv[2]]}, ensure_ascii=False))' "$RATING" "$ADVICE"
    exit 0
  fi
  python3 -c 'import json; print(json.dumps({"ok": False, "error":"error_spasm_core_evaluate_mix"}, ensure_ascii=False))'
  exit 1
fi

if [[ "$METHOD" == "format_analysis_summary" ]]; then
  PAYLOAD="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[])
label=a[0] if len(a)>0 else "Análisis"
stats=a[1] if len(a)>1 and isinstance(a[1],dict) else {}
band_stats=a[2] if len(a)>2 and isinstance(a[2],dict) else {}
voice_rms=a[3] if len(a)>3 else None
target_lufs=float(a[4] if len(a)>4 else -14.0)
true_peak=float(a[5] if len(a)>5 else -1.0)
band_labels=[
    "Subbass (20-60 Hz)",
    "Bass (60-250 Hz)",
    "Low-Mid (250-500 Hz)",
    "Mid (500-2k Hz)",
    "High-Mid (2k-6k Hz)",
    "Air (6k-16k Hz)",
]
def f(v,default=0.0):
    try:
        return float(v)
    except Exception:
        return float(default)
def s2(v):
    return f"{f(v):.2f}"
print(label)
print(s2(stats.get("input_i",0.0)))
print(s2(stats.get("input_tp",0.0)))
print(s2(stats.get("input_lra",0.0)))
print(int(round(f(stats.get("input_i",0.0))*100.0)))
print(int(round(f(stats.get("input_tp",0.0))*100.0)))
print(int(round(f(stats.get("input_lra",0.0))*100.0)))
print(int(round(f(stats.get("target_offset",0.0))*100.0)))
print(int(round(target_lufs*100.0)))
print(int(round(true_peak*100.0)))
if isinstance(voice_rms, (int, float)):
    print(1)
    print(f"{float(voice_rms):.2f}")
else:
    print(0)
    print("")
for label in band_labels:
    if label in band_stats:
        print(s2(band_stats.get(label, 0.0)))
    else:
        print("")
PY
)"
  CORE_OUT="$(printf '%s\n%s\n' "$METHOD" "$PAYLOAD" | "$SPASM_BIN" "$CORE_SCRIPT" 2>/dev/null || true)"
  STATUS="$(printf '%s\n' "$CORE_OUT" | sed -n '1p')"
  if [[ "$STATUS" == "OK" ]]; then
    SUMMARY="$(printf '%s\n' "$CORE_OUT" | sed '1d')"
    python3 -c 'import json,sys; print(json.dumps({"ok": True, "result": sys.argv[1]}, ensure_ascii=False))' "$SUMMARY"
    exit 0
  fi
  ERROR="$(printf '%s\n' "$CORE_OUT" | sed -n '2p')"
  python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": sys.argv[1] or "error_spasm_core_format_analysis_summary"}, ensure_ascii=False))' "$ERROR"
  exit 1
fi

if [[ "$METHOD" == "write_analysis_toml" ]]; then
  python3 - <<'PY' "$REQ"
import json,sys,pathlib
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
def uw(v):
    if isinstance(v,dict) and v.get("__type__")=="path":
        return pathlib.Path(v.get("value",""))
    return v
a=[uw(x) for x in a]
kw={k: uw(v) for k,v in kw.items()}

def _f(v, default=0.0):
    try:
        return float(v)
    except Exception:
        return float(default)

def _esc(s: str) -> str:
    return str(s).replace("\\", "\\\\").replace('"', '\\"')

(
    output_path,
    target_lufs,
    true_peak,
    loudness_preset,
    output_preset,
    output_sr,
    output_bit_depth,
    output_format,
    dynamic_eq,
    stereo_width,
    brickwall,
    analyze_only,
    deesser,
    fade_in,
    fade_out,
    signature,
    before_stats,
    before_band,
    before_voice,
    after_stats,
    after_band,
    after_voice,
    before_rating,
    before_advice,
    after_rating,
    after_advice,
    resource_info,
) = (a + [None] * 27)[:27]

# Soporte kwargs (llamado principal desde workers).
if output_path is None:
    output_path = kw.get("output_path")
if target_lufs is None:
    target_lufs = kw.get("target_lufs")
if true_peak is None:
    true_peak = kw.get("true_peak")
if loudness_preset is None:
    loudness_preset = kw.get("loudness_preset")
if output_preset is None:
    output_preset = kw.get("output_preset")
if output_sr is None:
    output_sr = kw.get("output_sr")
if output_bit_depth is None:
    output_bit_depth = kw.get("output_bit_depth")
if output_format is None:
    output_format = kw.get("output_format")
if dynamic_eq is None:
    dynamic_eq = kw.get("dynamic_eq")
if stereo_width is None:
    stereo_width = kw.get("stereo_width")
if brickwall is None:
    brickwall = kw.get("brickwall")
if analyze_only is None:
    analyze_only = kw.get("analyze_only")
if deesser is None:
    deesser = kw.get("deesser")
if fade_in is None:
    fade_in = kw.get("fade_in")
if fade_out is None:
    fade_out = kw.get("fade_out")
if signature is None:
    signature = kw.get("signature")
if before_stats is None:
    before_stats = kw.get("before_stats")
if before_band is None:
    before_band = kw.get("before_band")
if before_voice is None:
    before_voice = kw.get("before_voice")
if after_stats is None:
    after_stats = kw.get("after_stats")
if after_band is None:
    after_band = kw.get("after_band")
if after_voice is None:
    after_voice = kw.get("after_voice")
if before_rating is None:
    before_rating = kw.get("before_rating")
if before_advice is None:
    before_advice = kw.get("before_advice")
if after_rating is None:
    after_rating = kw.get("after_rating")
if after_advice is None:
    after_advice = kw.get("after_advice")
if resource_info is None:
    resource_info = kw.get("resource_info")

if output_path is None:
    print(json.dumps({"ok": False, "error": "write_analysis_toml requiere output_path"}, ensure_ascii=False))
    raise SystemExit(1)

output_path = pathlib.Path(output_path)
log_dir = output_path.parent / "log"
log_dir.mkdir(parents=True, exist_ok=True)
toml_path = log_dir / f"{output_path.stem}.toml"

before_stats = before_stats if isinstance(before_stats, dict) else {}
after_stats = after_stats if isinstance(after_stats, dict) else {}
before_band = before_band if isinstance(before_band, dict) else {}
after_band = after_band if isinstance(after_band, dict) else {}
signature = signature if isinstance(signature, dict) else {}
resource_info = resource_info if isinstance(resource_info, dict) else {}

lines=[]
lines.append("[settings]")
lines.append(f'loudness_preset = "{_esc(loudness_preset or "Manual")}"')
lines.append(f'output_preset = "{_esc(output_preset or "Manual")}"')
lines.append(f'output_format = "{_esc((output_format or "wav"))}"')
lines.append(f"target_lufs = {_f(target_lufs, -14.0):.2f}")
lines.append(f"true_peak = {_f(true_peak, -1.0):.2f}")
lines.append(f"dynamic_eq = {'true' if bool(dynamic_eq) else 'false'}")
lines.append(f"stereo_width = {'true' if bool(stereo_width) else 'false'}")
lines.append(f"brickwall = {'true' if bool(brickwall) else 'false'}")
lines.append(f"deesser = {'true' if bool(deesser) else 'false'}")
lines.append(f"fade_in = {_f(fade_in, 0.0):.2f}")
lines.append(f"fade_out = {_f(fade_out, 0.0):.2f}")
lines.append(f"analyze_only = {'true' if bool(analyze_only) else 'false'}")
if output_sr is not None:
    lines.append(f"output_sample_rate = {int(output_sr)}")
if output_bit_depth is not None:
    lines.append(f'output_bit_depth = "{_esc(output_bit_depth)}"')

if signature:
    lines.append("[signature]")
    for k,v in signature.items():
        if v is not None:
            lines.append(f'{k} = "{_esc(v)}"')

cpu = resource_info.get("cpu", {}) if isinstance(resource_info.get("cpu"), dict) else {}
gpu = resource_info.get("gpu", {}) if isinstance(resource_info.get("gpu"), dict) else {}
engine = resource_info.get("engine", {}) if isinstance(resource_info.get("engine"), dict) else {}
summary = resource_info.get("summary")
if summary is not None or cpu or gpu or engine:
    lines.append("[resources]")
    lines.append(f'resource_summary = "{_esc(summary or "")}"')
    if cpu:
        lines.append("[resources.cpu]")
        for k in ("cpu_count","cpu_percent","memory_percent","memory_available_gb","ffmpeg_processes"):
            if k in cpu and cpu[k] is not None:
                v = cpu[k]
                if isinstance(v, bool):
                    lines.append(f"{k} = {'true' if v else 'false'}")
                elif isinstance(v, (int,float)):
                    lines.append(f"{k} = {v}")
                else:
                    lines.append(f'{k} = "{_esc(v)}"')
    if gpu:
        lines.append("[resources.gpu]")
        for k,v in gpu.items():
            if v is None:
                continue
            if isinstance(v, bool):
                lines.append(f"{k} = {'true' if v else 'false'}")
            elif isinstance(v, (int,float)):
                lines.append(f"{k} = {v}")
            else:
                lines.append(f'{k} = "{_esc(v)}"')
    if engine:
        lines.append("[resources.engine]")
        for k,v in engine.items():
            if v is None:
                continue
            if isinstance(v, bool):
                lines.append(f"{k} = {'true' if v else 'false'}")
            elif isinstance(v, (int,float)):
                lines.append(f"{k} = {v}")
            else:
                lines.append(f'{k} = "{_esc(v)}"')

def _render_block(name, stats, band, voice, rating, advice):
    out=[]
    out.append(f"[{name}]")
    out.append(f"input_i = {_f(stats.get('input_i',0.0)):.2f}")
    out.append(f"input_tp = {_f(stats.get('input_tp',0.0)):.2f}")
    out.append(f"input_lra = {_f(stats.get('input_lra',0.0)):.2f}")
    out.append(f"input_thresh = {_f(stats.get('input_thresh',0.0)):.2f}")
    out.append(f"target_offset = {_f(stats.get('target_offset',0.0)):.2f}")
    if voice is not None:
        out.append(f"voice_rms = {_f(voice,0.0):.2f}")
    out.append(f'rating = "{_esc(rating or "")}"')
    out.append(f'advice = "{_esc(advice or "")}"')
    if band:
        out.append(f"[{name}.bands]")
        for k,v in band.items():
            out.append(f'"{_esc(k)}" = {_f(v,0.0):.2f}')
    return out

lines.extend(_render_block("before", before_stats, before_band, before_voice, before_rating, before_advice))
if after_stats:
    lines.extend(_render_block("after", after_stats, after_band, after_voice, after_rating, after_advice))

toml_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
res=toml_path
print(json.dumps({"ok": True, "result": {"__type__":"path","value":str(res)}}, ensure_ascii=False))
PY
  exit $?
fi

if [[ "$METHOD" == "analyze_audio" ]]; then
  INPUT_PATH="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
v=a[0] if len(a)>0 else kw.get("input_path","")
if isinstance(v,dict) and v.get("__type__")=="path":
    v=v.get("value","")
print(str(v))
PY
)"
  TARGET_LUFS="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
print(float(a[1] if len(a)>1 else kw.get("target_lufs",-14.0)))
PY
)"
  TRUE_PEAK="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
print(float(a[2] if len(a)>2 else kw.get("true_peak",-1.0)))
PY
)"

  if [[ ! -f "$INPUT_PATH" ]]; then
    python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": f"archivo no existe: {sys.argv[1]}"}, ensure_ascii=False))' "$INPUT_PATH"
    exit 1
  fi

  ANALYZE_OUT="$(
    "$FFMPEG_BIN" -hide_banner -nostdin -i "$INPUT_PATH" \
      -af "loudnorm=I=${TARGET_LUFS}:LRA=11:TP=${TRUE_PEAK}:print_format=json" \
      -f null - 2>&1 || true
  )"

  LOUDNORM_JSON="$(printf '%s\n' "$ANALYZE_OUT" | awk '
    BEGIN {cap=0; blk=""; last=""}
    /^\s*\{/ {cap=1; blk=$0 ORS; next}
    cap==1 {
      blk=blk $0 ORS
      if ($0 ~ /^\s*\}/) {
        if (blk ~ /"input_i"/) { last=blk }
        cap=0; blk=""
      }
    }
    END { printf "%s", last }
  ')"

  if [[ -z "${LOUDNORM_JSON// }" ]]; then
    python3 - <<'PY' "$ANALYZE_OUT"
import json,sys
print(json.dumps({"ok": False, "error": "no se pudo extraer JSON de loudnorm", "raw": sys.argv[1][-2000:]}, ensure_ascii=False))
PY
    exit 1
  fi

  python3 - <<'PY' "$LOUDNORM_JSON" "$ANALYZE_OUT"
import json,sys,math
raw_json=sys.argv[1]
log=sys.argv[2]
try:
    data=json.loads(raw_json)
except Exception as e:
    print(json.dumps({"ok": False, "error": f"json loudnorm inválido: {e}"}, ensure_ascii=False))
    raise SystemExit(1)

def f(key, default):
    try:
        v=float(data.get(key, default))
        if math.isinf(v) and v < 0:
            return -70.0
        if math.isinf(v) or math.isnan(v):
            return float(default)
        return v
    except Exception:
        return float(default)

stats={
    "input_i": f("input_i", -23.0),
    "input_tp": f("input_tp", -1.0),
    "input_lra": f("input_lra", 7.0),
    "input_thresh": f("input_thresh", -33.0),
    "target_offset": f("target_offset", 0.0),
}
print(json.dumps({"ok": True, "result": {"__type__":"tuple","value":[stats,log]}}, ensure_ascii=False))
PY
  exit $?
fi

if [[ "$METHOD" == "analyze_eq_bands" ]]; then
  META="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
v=a[0] if len(a)>0 else kw.get("input_path","")
if isinstance(v,dict) and v.get("__type__")=="path":
    v=v.get("value","")
verbose=bool(a[1]) if len(a)>1 else bool(kw.get("verbose",False))
band_range=float(a[2] if len(a)>2 else kw.get("band_range_db",3.0))
print(json.dumps({"input_path": str(v), "verbose": verbose, "band_range_db": band_range}, ensure_ascii=False))
PY
)"
  INPUT_PATH="$(python3 - <<'PY' "$META"
import json,sys
print(json.loads(sys.argv[1])["input_path"])
PY
)"
  BAND_RANGE_DB="$(python3 - <<'PY' "$META"
import json,sys
print(float(json.loads(sys.argv[1])["band_range_db"]))
PY
)"

  if [[ ! -f "$INPUT_PATH" ]]; then
    python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": f"archivo no existe: {sys.argv[1]}"}, ensure_ascii=False))' "$INPUT_PATH"
    exit 1
  fi

  # Band config estable (label|low|high)
  BANDS=(
    "Subbass (20-60 Hz)|20|60"
    "Bass (60-250 Hz)|60|250"
    "Low-Mid (250-500 Hz)|250|500"
    "Mid (500-2k Hz)|500|2000"
    "High-Mid (2k-6k Hz)|2000|6000"
    "Air (6k-16k Hz)|6000|16000"
  )

  # Fast path: todas las bandas en una sola corrida FFmpeg (filter_complex).
  FILTER_COMPLEX="[0:a]asplit=6[b0][b1][b2][b3][b4][b5];"
  MAP_ARGS=()
  IDX=0
  for B in "${BANDS[@]}"; do
    REST="${B#*|}"
    LOW="${REST%%|*}"
    HIGH="${REST##*|}"
    FILTER_COMPLEX+="[b${IDX}]highpass=f=${LOW},lowpass=f=${HIGH},volumedetect[o${IDX}];"
    MAP_ARGS+=(-map "[o${IDX}]" -f null -)
    IDX=$((IDX+1))
  done
  FILTER_COMPLEX="${FILTER_COMPLEX%;}"

  OUT="$(
    "$FFMPEG_BIN" -hide_banner -nostdin -i "$INPUT_PATH" \
      -filter_complex "$FILTER_COMPLEX" \
      "${MAP_ARGS[@]}" 2>&1 || true
  )"

  BAND_LINES="$(python3 - <<'PY' "$OUT"
import re,sys
text=sys.argv[1]
mean_re=re.compile(r"Parsed_volumedetect_(\d+).*mean_volume:\s*(-?\d+(?:\.\d+)?)\s*dB")
peak_re=re.compile(r"Parsed_volumedetect_(\d+).*max_volume:\s*(-?\d+(?:\.\d+)?)\s*dB")
means={}
peaks={}
for line in text.splitlines():
    m=mean_re.search(line)
    if m:
        means[int(m.group(1))]=m.group(2)
        continue
    p=peak_re.search(line)
    if p:
        peaks[int(p.group(1))]=p.group(2)

# Mapear por orden de índice del filtro volumedetect.
for idx in sorted(set(means.keys()) | set(peaks.keys())):
    mean=means.get(idx,"-80.0")
    peak=peaks.get(idx,"-100.0")
    print(f"{idx}\t{mean}\t{peak}")
PY
)"

  # Fallback robusto: si el parseo rápido no devolvió 6 bandas, usar modo secuencial legado.
  FAST_COUNT="$(printf '%s\n' "$BAND_LINES" | sed '/^[[:space:]]*$/d' | wc -l)"
  if [[ "$FAST_COUNT" -lt 6 ]]; then
    BAND_LINES=""
    for B in "${BANDS[@]}"; do
      LABEL="${B%%|*}"
      REST="${B#*|}"
      LOW="${REST%%|*}"
      HIGH="${REST##*|}"
      OUT="$(
        "$FFMPEG_BIN" -hide_banner -nostdin -i "$INPUT_PATH" \
          -af "highpass=f=${LOW},lowpass=f=${HIGH},volumedetect" \
          -f null - 2>&1 || true
      )"
      MEAN="$(printf '%s\n' "$OUT" | sed -nE 's/.*mean_volume:[[:space:]]*(-?[0-9]+(\.[0-9]+)?) dB.*/\1/p' | tail -n1)"
      PEAK="$(printf '%s\n' "$OUT" | sed -nE 's/.*max_volume:[[:space:]]*(-?[0-9]+(\.[0-9]+)?) dB.*/\1/p' | tail -n1)"
      [[ -z "${MEAN// }" ]] && MEAN="-80.0"
      [[ -z "${PEAK// }" ]] && PEAK="-100.0"
      BAND_LINES+="${LABEL}"$'\t'"${MEAN}"$'\t'"${PEAK}"$'\n'
    done
  else
    # Rehidratar índices a labels por orden de aparición (los IDs Parsed_* no siempre arrancan en 0).
    BAND_LINES="$(python3 - <<'PY' "$BAND_LINES"
import sys
bands=[
    "Subbass (20-60 Hz)",
    "Bass (60-250 Hz)",
    "Low-Mid (250-500 Hz)",
    "Mid (500-2k Hz)",
    "High-Mid (2k-6k Hz)",
    "Air (6k-16k Hz)",
]
rows=[]
for line in sys.argv[1].splitlines():
    if not line.strip():
        continue
    try:
        idx_s,mean,peak=line.split("\t")
        idx=int(idx_s)
    except Exception:
        continue
    rows.append((idx,mean,peak))

rows.sort(key=lambda t: t[0])
for pos,(_idx,mean,peak) in enumerate(rows[:len(bands)]):
    print(f"{bands[pos]}\t{mean}\t{peak}")
PY
)"
    FINAL_COUNT="$(printf '%s\n' "$BAND_LINES" | sed '/^[[:space:]]*$/d' | wc -l)"
    if [[ "$FINAL_COUNT" -lt 6 ]]; then
      BAND_LINES=""
      for B in "${BANDS[@]}"; do
        LABEL="${B%%|*}"
        REST="${B#*|}"
        LOW="${REST%%|*}"
        HIGH="${REST##*|}"
        OUT="$(
          "$FFMPEG_BIN" -hide_banner -nostdin -i "$INPUT_PATH" \
            -af "highpass=f=${LOW},lowpass=f=${HIGH},volumedetect" \
            -f null - 2>&1 || true
        )"
        MEAN="$(printf '%s\n' "$OUT" | sed -nE 's/.*mean_volume:[[:space:]]*(-?[0-9]+(\.[0-9]+)?) dB.*/\1/p' | tail -n1)"
        PEAK="$(printf '%s\n' "$OUT" | sed -nE 's/.*max_volume:[[:space:]]*(-?[0-9]+(\.[0-9]+)?) dB.*/\1/p' | tail -n1)"
        [[ -z "${MEAN// }" ]] && MEAN="-80.0"
        [[ -z "${PEAK// }" ]] && PEAK="-100.0"
        BAND_LINES+="${LABEL}"$'\t'"${MEAN}"$'\t'"${PEAK}"$'\n'
      done
    fi
  fi

  python3 - <<'PY' "$BAND_LINES" "$BAND_RANGE_DB"
import json,sys
raw=sys.argv[1]
band_range=float(sys.argv[2])
results={}
peaks={}
for line in raw.splitlines():
    if not line.strip():
        continue
    try:
        label,mean,peak=line.split("\t")
        results[label]=max(-80.0,float(mean))
        peaks[label]=float(peak)
    except Exception:
        continue

suggestions=[]
if results:
    avg=sum(results.values())/len(results)
    for label,rms_level in results.items():
        peak_db=peaks.get(label,-100.0)
        if peak_db > -1.0 and label in ("High-Mid (2k-6k Hz)", "Air (6k-16k Hz)"):
            suggestions.append(f"{label}: ADVERTENCIA - pico cercano a 0dB ({peak_db:.1f}dB), riesgo de saturación!")
        elif rms_level > avg + band_range:
            suggestions.append(f"{label}: posible exceso; considera bajar ~2-3 dB.")
        elif rms_level < avg - band_range:
            if label in ("High-Mid (2k-6k Hz)", "Air (6k-16k Hz)") and peak_db > -3.0:
                continue
            suggestions.append(f"{label}: posible falta; considera subir ~2-3 dB.")

print(json.dumps({"ok": True, "result": {"__type__":"tuple","value":[results,suggestions]}}, ensure_ascii=False))
PY
  exit $?
fi

