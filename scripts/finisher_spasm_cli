if [[ "$METHOD" == "build_preprocess_chain" ]]; then
  HEADROOM_EFFECTIVE="$(python3 - <<'PY' "$REQ"
import json,sys,math
d=json.loads(sys.argv[1]); kw=d.get("kwargs",{}) or {}
def b(name, default=False):
    v=kw.get(name, default)
    if isinstance(v,bool): return v
    if isinstance(v,(int,float)): return v != 0
    if isinstance(v,str):
        t=v.strip().lower()
        if t in ("1","true","yes","on","si","sí"): return True
        if t in ("0","false","no","off",""): return False
    return bool(v)
def f(name, default=0.0):
    try:
        return float(kw.get(name, default) or default)
    except Exception:
        return float(default)
base=f("headroom_db",-17.0)
lift=0.0
lift += max(0.0, f("tone_mid_db",0.0)) * 0.25
lift += max(0.0, f("sub_bass_db",0.0)) * 0.20
lift += max(0.0, f("tone_high_db",0.0) + f("tone_tilt_db",0.0)) * 0.35
if b("deesser",False):
    lift += 0.8
if b("glue_enabled",False):
    lift += 1.0
if b("saturation_enabled",False):
    drive=abs(f("saturation_drive_db",0.0))
    mix=max(0.0,min(1.0,f("saturation_mix",0.0)))
    lift += min(2.0, drive*0.20 + mix*2.0)
if b("autogain_enabled",True):
    maxg=max(1.0,f("autogain_maxgain",1.35))
    lift += max(0.0, maxg-1.0) * 1.2
eff = base - lift
eff = max(-24.0, min(-14.0, eff))
print(f"{eff:.2f}")
PY
)"

  if ! PAYLOAD="$(python3 - <<'PY' "$REQ" 2>&1
import json,sys
d=json.loads(sys.argv[1]); kw=d.get("kwargs",{}) or {}
def bget(name,default=False):
    v=kw.get(name,default)
    if isinstance(v,bool):
        return v
    if isinstance(v,(int,float)):
        return v != 0
    if isinstance(v,str):
        t=v.strip().lower()
        if t in ("1","true","yes","on","si","sí"):
            return True
        if t in ("0","false","no","off",""):
            return False
    return bool(v)
def b(name,default=False):
    print(1 if bget(name,default) else 0)
def f(name,default=0.0):
    try:
        v=float(kw.get(name,default) or default)
    except Exception:
        v=float(default)
    print(v)
b("mix_enabled", True)
b("autogain_enabled", True)
b("stereo_width", False)
f("headroom_db", -17.0)
b("deesser", False)
f("deesser_freq_hz", 6000.0)
f("deesser_intensity", 1.0)
print(str(kw.get("noise_reduction_level","Off") or "Off"))
print(str(kw.get("declip_level","Off") or "Off"))
print(str(kw.get("declick_level","Off") or "Off"))
def fget(name, default=0.0):
    try:
        return float(kw.get(name, default) or default)
    except Exception:
        return float(default)
low=fget("tone_low_db",0.0)
tilt=fget("tone_tilt_db",0.0)
high=fget("tone_high_db",0.0)
print(low - tilt)   # tone_low_effective_db
f("sub_bass_db", 0.0)
f("tone_mid_db", 0.0)
print(high + tilt)  # tone_high_effective_db
b("saturation_enabled", False)
b("saturation_per_band", False)
f("saturation_drive_db", 0.0)
f("saturation_mix", 0.0)
v=kw.get("saturation_type","Tape")
print(str(v) if v is not None else "Tape")
b("glue_enabled", False)
f("glue_threshold_db", -18.0)
f("glue_ratio", 1.4)
f("glue_attack_ms", 20.0)
f("glue_release_ms", 120.0)
f("glue_makeup_db", 0.0)
f("autogain_maxgain", 2.0)
PY
  )"; then
    python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": "build_preprocess_chain_payload_error", "detail": sys.argv[1][-1200:]}, ensure_ascii=False))' "$PAYLOAD"
    exit 1
  fi

  CORE_OUT="$(printf '%s\n%s\n' "$METHOD" "$PAYLOAD" | "$SPASM_BIN" "$CORE_SCRIPT" 2>/dev/null || true)"
  STATUS="$(printf '%s\n' "$CORE_OUT" | sed -n '1p')"
  CHAIN="$(printf '%s\n' "$CORE_OUT" | sed -n '2p')"
  OUTLBL="$(printf '%s\n' "$CORE_OUT" | sed -n '3p')"
  if [[ "$STATUS" == "OK" ]]; then
    CHAIN="$(python3 - <<'PY' "$CHAIN" "$HEADROOM_EFFECTIVE"
import sys,re
chain=sys.argv[1]
hr=float(sys.argv[2])
out=re.sub(r'volume=-17\.0dB', f'volume={hr:.2f}dB', chain, count=1)
print(out)
PY
)"
    python3 -c 'import json,sys; print(json.dumps({"ok": True, "result": {"__type__":"tuple","value":[sys.argv[1],sys.argv[2]]}}, ensure_ascii=False))' "$CHAIN" "$OUTLBL"
    exit 0
  fi
  python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": sys.argv[1] or "error_spasm_core_build_preprocess_chain"}, ensure_ascii=False))' "$CHAIN"
  exit $?
fi

if [[ "$METHOD" == "analyze_audio_with_filter" ]]; then
  META="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
def path_of(v):
    if isinstance(v,dict) and v.get("__type__")=="path":
        return str(v.get("value",""))
    return str(v)
input_path=path_of(a[0]) if len(a)>0 else path_of(kw.get("input_path",""))
target_lufs=float(a[1] if len(a)>1 else kw.get("target_lufs",-14.0))
true_peak=float(a[2] if len(a)>2 else kw.get("true_peak",-1.0))
filter_chain=str(a[3]) if len(a)>3 else str(kw.get("filter_chain",""))
filter_output=str(a[4]) if len(a)>4 else str(kw.get("filter_output",""))
print(json.dumps({
  "input_path": input_path,
  "target_lufs": target_lufs,
  "true_peak": true_peak,
  "filter_chain": filter_chain,
  "filter_output": filter_output
}, ensure_ascii=False))
PY
)"

  INPUT_PATH="$(python3 - <<'PY' "$META"
import json,sys
print(json.loads(sys.argv[1])["input_path"])
PY
)"
  TARGET_LUFS="$(python3 - <<'PY' "$META"
import json,sys
print(float(json.loads(sys.argv[1])["target_lufs"]))
PY
)"
  TRUE_PEAK="$(python3 - <<'PY' "$META"
import json,sys
print(float(json.loads(sys.argv[1])["true_peak"]))
PY
)"
  FILTER_CHAIN="$(python3 - <<'PY' "$META"
import json,sys
print(json.loads(sys.argv[1])["filter_chain"])
PY
)"
  FILTER_OUTPUT="$(python3 - <<'PY' "$META"
import json,sys
print(json.loads(sys.argv[1])["filter_output"])
PY
)"

  if [[ ! -f "$INPUT_PATH" ]]; then
    python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": f"archivo no existe: {sys.argv[1]}"}, ensure_ascii=False))' "$INPUT_PATH"
    exit 1
  fi

  if [[ -n "$FILTER_CHAIN" && -n "$FILTER_OUTPUT" ]]; then
    FILTER_COMPLEX="${FILTER_CHAIN};[${FILTER_OUTPUT}]loudnorm=I=${TARGET_LUFS}:LRA=11:TP=${TRUE_PEAK}:print_format=json[out]"
    ANALYZE_OUT="$(
      "$FFMPEG_BIN" -hide_banner -nostdin -i "$INPUT_PATH" \
        -filter_complex "$FILTER_COMPLEX" -map "[out]" \
        -f null - 2>&1 || true
    )"
  else
    ANALYZE_OUT="$(
      "$FFMPEG_BIN" -hide_banner -nostdin -i "$INPUT_PATH" \
        -af "loudnorm=I=${TARGET_LUFS}:LRA=11:TP=${TRUE_PEAK}:print_format=json" \
        -f null - 2>&1 || true
    )"
  fi

  LOUDNORM_JSON="$(printf '%s\n' "$ANALYZE_OUT" | awk '
    BEGIN {cap=0; blk=""; last=""}
    /^\s*\{/ {cap=1; blk=$0 ORS; next}
    cap==1 {
      blk=blk $0 ORS
      if ($0 ~ /^\s*\}/) {
        if (blk ~ /"input_i"/) { last=blk }
        cap=0; blk=""
      }
    }
    END { printf "%s", last }
  ')"

  if [[ -z "${LOUDNORM_JSON// }" ]]; then
    python3 - <<'PY' "$ANALYZE_OUT"
import json,sys
print(json.dumps({"ok": False, "error": "no se pudo extraer JSON de loudnorm", "raw": sys.argv[1][-2000:]}, ensure_ascii=False))
PY
    exit 1
  fi

  python3 - <<'PY' "$LOUDNORM_JSON" "$ANALYZE_OUT"
import json,sys,math
raw_json=sys.argv[1]
log=sys.argv[2]
try:
    data=json.loads(raw_json)
except Exception as e:
    print(json.dumps({"ok": False, "error": f"json loudnorm inválido: {e}"}, ensure_ascii=False))
    raise SystemExit(1)

def f(key, default):
    try:
        v=float(data.get(key, default))
        if math.isinf(v) and v < 0:
            return -70.0
        if math.isinf(v) or math.isnan(v):
            return float(default)
        return v
    except Exception:
        return float(default)

stats={
    "input_i": f("input_i", -23.0),
    "input_tp": f("input_tp", -1.0),
    "input_lra": f("input_lra", 7.0),
    "input_thresh": f("input_thresh", -33.0),
    "target_offset": f("target_offset", 0.0),
}
print(json.dumps({"ok": True, "result": {"__type__":"tuple","value":[stats,log]}}, ensure_ascii=False))
PY
  exit $?
fi

if [[ "$METHOD" == "apply_output_gain" ]]; then
  META="$(python3 - <<'PY' "$REQ"
import json,sys
d=json.loads(sys.argv[1]); a=d.get("args",[]); kw=d.get("kwargs",{}) or {}
def path_of(v):
