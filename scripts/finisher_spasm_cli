  # Build preprocess chain via core SpASM
  HEADROOM_EFFECTIVE="$(python3 - <<'PY' "$META"
import json,sys
m=json.loads(sys.argv[1])
def b(v, d=False):
    if v is None: return d
    if isinstance(v,bool): return v
    if isinstance(v,(int,float)): return v != 0
    if isinstance(v,str):
        t=v.strip().lower()
        if t in ("1","true","yes","on","si","sí"): return True
        if t in ("0","false","no","off",""): return False
    return bool(v)
def f(v, d=0.0):
    try: return float(v)
    except Exception: return float(d)
base=f(m.get("headroom_db",-17.0),-17.0)
lift=0.0
lift += max(0.0, f(m.get("tone_mid_db",0.0),0.0))*0.25
lift += max(0.0, f(m.get("sub_bass_db",0.0),0.0))*0.20
lift += max(0.0, f(m.get("tone_high_db",0.0),0.0)+f(m.get("tone_tilt_db",0.0),0.0))*0.35
if b(m.get("deesser",False),False): lift += 0.8
if b(m.get("glue_enabled",False),False): lift += 1.0
if b(m.get("saturation_enabled",False),False):
    drive=abs(f(m.get("saturation_drive_db",0.0),0.0))
    mix=max(0.0,min(1.0,f(m.get("saturation_mix",0.0),0.0)))
    lift += min(2.0, drive*0.20 + mix*2.0)
if b(m.get("autogain_enabled",True),True):
    maxg=max(1.0,f(m.get("autogain_maxgain",1.35),1.35))
    lift += max(0.0,maxg-1.0)*1.2
eff=max(-24.0,min(-14.0,base-lift))
print(f"{eff:.2f}")
PY
)"
  BP_REQ="$(python3 - "$META" "$HEADROOM_EFFECTIVE" <<'PY'
import json,sys
m=json.loads(sys.argv[1])
req={"method":"build_preprocess_chain","args":[],"kwargs":{
  "mix_enabled":m["mix_enabled"], "autogain_enabled":m["autogain_enabled"],
  "stereo_width":m["stereo_width"],
  "headroom_db":float(sys.argv[2]),
  "deesser":m["deesser"], "deesser_freq_hz":m["deesser_freq_hz"], "deesser_intensity":m["deesser_intensity"],
  "noise_reduction_level":m["noise_reduction_level"], "declip_level":m["declip_level"], "declick_level":m["declick_level"],
  "tone_low_db":m["tone_low_db"], "sub_bass_db":m["sub_bass_db"], "tone_mid_db":m["tone_mid_db"], "tone_high_db":m["tone_high_db"], "tone_tilt_db":m["tone_tilt_db"],
  "saturation_enabled":m["saturation_enabled"], "saturation_per_band":m["saturation_per_band"],
  "saturation_drive_db":m["saturation_drive_db"], "saturation_mix":m["saturation_mix"], "saturation_type":m["saturation_type"],
  "glue_enabled":m["glue_enabled"], "glue_threshold_db":m["glue_threshold_db"], "glue_ratio":m["glue_ratio"],
  "glue_attack_ms":m["glue_attack_ms"], "glue_release_ms":m["glue_release_ms"], "glue_makeup_db":m["glue_makeup_db"],
  "autogain_maxgain":m["autogain_maxgain"],
}}
print(json.dumps(req, ensure_ascii=False))
PY
)"
  BP_RES="$(printf '%s' "$BP_REQ" | "$0" call --json)"
  readarray -t BP_LINES < <(python3 - <<'PY' "$BP_RES"
import json,sys
r=json.loads(sys.argv[1])
if not r.get("ok"):
    print(""); print(""); raise SystemExit(1)
t=r["result"]
vals=t.get("value",[]) if isinstance(t,dict) else []
print(vals[0] if len(vals)>0 else "")
print(vals[1] if len(vals)>1 else "")
PY
)
  PRE_CHAIN="${BP_LINES[0]}"
  PRE_OUT="${BP_LINES[1]}"

  LOUDNORM_TARGETS="$(python3 - <<'PY' "$META" "$TARGET_LUFS" "$TRUE_PEAK"
import json,sys
m=json.loads(sys.argv[1]); target=float(sys.argv[2]); tp=float(sys.argv[3])
import os
def b(v, d=False):
    if v is None: return d
    if isinstance(v,bool): return v
    if isinstance(v,(int,float)): return v != 0
    if isinstance(v,str):
        t=v.strip().lower()
        if t in ("1","true","yes","on","si","sí"): return True
        if t in ("0","false","no","off",""): return False
    return bool(v)
def f(v, d=0.0):
    try: return float(v)
    except Exception: return float(d)
lift=0.0
lift += max(0.0, f(m.get("tone_mid_db",0.0),0.0))*0.25
lift += max(0.0, f(m.get("sub_bass_db",0.0),0.0))*0.20
lift += max(0.0, f(m.get("tone_high_db",0.0),0.0)+f(m.get("tone_tilt_db",0.0),0.0))*0.35
if b(m.get("deesser",False),False): lift += 0.8
if b(m.get("glue_enabled",False),False): lift += 1.0
if b(m.get("saturation_enabled",False),False):
    drive=abs(f(m.get("saturation_drive_db",0.0),0.0))
    mix=max(0.0,min(1.0,f(m.get("saturation_mix",0.0),0.0)))
    lift += min(2.0, drive*0.20 + mix*2.0)
if b(m.get("autogain_enabled",True),True):
    maxg=max(1.0,f(m.get("autogain_maxgain",1.35),1.35))
    lift += max(0.0,maxg-1.0)*1.2
# Compensación empírica por desvío de FFmpeg (calibrable por entorno)
lufs_comp=f(os.getenv("TONEFINISH_FFMPEG_LUFS_COMP_DB","0.0"),0.0)
tp_comp=f(os.getenv("TONEFINISH_FFMPEG_TP_COMP_DB","0.0"),0.0)
lufs_comp=max(-0.60,min(0.60,lufs_comp))
tp_comp=max(0.0,min(0.90,tp_comp))

# margen dinámico adicional por cadena activa (más cercano al target real)
margin=min(1.15, 0.22 + lift*0.15)
target_eff = target + lufs_comp
tp_eff = tp - margin - tp_comp
print(f"{target_eff:.3f}")
print(f"{tp_eff:.3f}")
PY
)"
  TARGET_LUFS_EFFECTIVE="$(printf '%s\n' "$LOUDNORM_TARGETS" | sed -n '1p')"
  TP_EFFECTIVE="$(printf '%s\n' "$LOUDNORM_TARGETS" | sed -n '2p')"
  LOUDNORM_FILTER="loudnorm=I=${TARGET_LUFS_EFFECTIVE}:LRA=11:TP=${TP_EFFECTIVE}:print_format=summary"

  FILTER_COMPLEX=""
  if [[ "$MASTER_ENABLED" == "1" ]]; then
    if [[ -n "$PRE_CHAIN" && -n "$PRE_OUT" ]]; then
      FILTER_COMPLEX="${PRE_CHAIN};[${PRE_OUT}]${LOUDNORM_FILTER}[out]"
    else
      FILTER_COMPLEX="[0:a]${LOUDNORM_FILTER}[out]"
    fi
  else
    if [[ -n "$PRE_CHAIN" && -n "$PRE_OUT" ]]; then
      FILTER_COMPLEX="${PRE_CHAIN};[${PRE_OUT}]anull[out]"
    else
      FILTER_COMPLEX="[0:a]anull[out]"
    fi
  fi

  if [[ "$(python3 - <<'PY' "$FADE_IN"
import sys; print(1 if float(sys.argv[1])>0 else 0)
PY
)" == "1" ]]; then
    FILTER_COMPLEX="${FILTER_COMPLEX};[out]afade=t=in:ss=0:d=${FADE_IN}[out]"
  fi
  if [[ "$(python3 - <<'PY' "$FADE_OUT"
import sys; print(1 if float(sys.argv[1])>0 else 0)
PY
)" == "1" ]]; then
    DUR="$("$FFPROBE_BIN" -v error -show_entries format=duration -of default=nk=1:nw=1 "$INPUT_PATH" || echo 0)"
    ST="$(python3 - <<'PY' "$DUR" "$FADE_OUT"
import sys
d=float(sys.argv[1] or 0); fo=float(sys.argv[2] or 0)
print(max(0.0,d-fo))
PY
)"
    FILTER_COMPLEX="${FILTER_COMPLEX};[out]afade=t=out:st=${ST}:d=${FADE_OUT}[out]"
  fi

  # `loudnorm` puede sacar 192kHz internamente; si no se pidió `output_sr`,
  # fijamos el sample rate de salida al del archivo de entrada.
  if [[ -z "$OUTPUT_SR" ]]; then
    OUTPUT_SR="$("$FFPROBE_BIN" -v error -select_streams a:0 -show_entries stream=sample_rate -of default=nk=1:nw=1 "$INPUT_PATH" 2>/dev/null | head -n1 || true)"
  fi

  FF_ARGS=()
  if [[ "$OVERWRITE_FLAG" == "1" ]]; then FF_ARGS+=("-y"); else FF_ARGS+=("-n"); fi
  FF_ARGS+=("-hide_banner" "-nostdin" "-i" "$INPUT_PATH" "-filter_complex" "$FILTER_COMPLEX" "-map" "[out]")
  if [[ -n "$OUTPUT_SR" ]]; then FF_ARGS+=("-ar" "$OUTPUT_SR"); fi
  case "$OUTPUT_FORMAT" in
    wav)
      if [[ "$OUTPUT_BIT_DEPTH" == "24" ]]; then FF_ARGS+=("-c:a" "pcm_s24le"); fi
      if [[ "$OUTPUT_BIT_DEPTH" == "16" ]]; then FF_ARGS+=("-c:a" "pcm_s16le"); fi
      ;;
    aiff|aif)
      if [[ "$OUTPUT_BIT_DEPTH" == "24" ]]; then FF_ARGS+=("-c:a" "pcm_s24be"); fi
      if [[ "$OUTPUT_BIT_DEPTH" == "16" ]]; then FF_ARGS+=("-c:a" "pcm_s16be"); fi
      ;;
    flac)
      FF_ARGS+=("-c:a" "flac")
      if [[ "$OUTPUT_BIT_DEPTH" == "16" ]]; then FF_ARGS+=("-sample_fmt" "s16"); fi
      if [[ "$OUTPUT_BIT_DEPTH" == "24" ]]; then FF_ARGS+=("-sample_fmt" "s32"); fi
      ;;
    m4a) FF_ARGS+=("-c:a" "aac" "-b:a" "256k");;
    mp3) FF_ARGS+=("-c:a" "libmp3lame" "-b:a" "320k");;
  esac
  while IFS= read -r meta_line; do FF_ARGS+=("-metadata" "$meta_line"); done < <(python3 - <<'PY' "$METADATA_JSON"
import json,sys
m=json.loads(sys.argv[1]) if sys.argv[1].strip() else {}
for k,v in (m.items() if isinstance(m,dict) else []):
    if v is None: continue
    s=str(v)
    if s: print(f"{k}={s}")
PY
)
  mkdir -p "$(dirname "$OUTPUT_PATH")"
  FF_ARGS+=("$OUTPUT_PATH")

  NORM_OUT="$("$FFMPEG_BIN" "${FF_ARGS[@]}" 2>&1)"
  NORM_RC=$?
  if [[ $NORM_RC -ne 0 ]]; then
    python3 - <<'PY' "$NORM_OUT"
import json,sys
print(json.dumps({"ok": False, "error": "ffmpeg falló en normalize_audio", "raw": sys.argv[1][-2500:]}, ensure_ascii=False))
PY
    exit 1
  fi
  python3 - <<'PY' "$NORM_OUT"
import json,sys
print(json.dumps({"ok": True, "result": sys.argv[1]}, ensure_ascii=False))
PY
  exit $?
fi

