  "output_sr": output_sr,
  "output_bit_depth": output_bit_depth,
  "output_format": output_format,
  "metadata": metadata
}, ensure_ascii=False))
PY
)"

  readarray -t APPLY_VARS < <(python3 - <<'PY' "$META"
import json,sys,math
m=json.loads(sys.argv[1])
def f(v,d=0.0):
    try: return float(v)
    except: return float(d)
input_path=m["input_path"]
output_path=m["output_path"]
gain_db=f(m["gain_db"],0.0)
true_peak=f(m["true_peak"],-1.0)
brickwall_extra_db=-0.5
limit_db=true_peak+brickwall_extra_db
lcdb=m.get("limiter_ceiling_db", None)
if lcdb is not None:
    try: limit_db=min(float(lcdb), limit_db)
    except: pass
release_ms=m.get("limiter_release_ms", None)
release_ms=100.0 if release_ms is None else max(10.0,float(release_ms))
attack_ms=1.0
limit_linear=max(0.0625,min(1.0,10**(limit_db/20.0)))
print(input_path)
print(output_path)
print(f"{gain_db:.4f}")
print(f"{limit_linear:.6f}")
print(f"{attack_ms:.1f}")
print(f"{release_ms:.1f}")
print("1" if m.get("overwrite",False) else "0")
print(m.get("output_sr") if m.get("output_sr") is not None else "")
print(m.get("output_bit_depth") if m.get("output_bit_depth") is not None else "")
print((m.get("output_format") or "").lower())
print(json.dumps(m.get("metadata",{}) or {}, ensure_ascii=False))
PY
)
  INPUT_PATH="${APPLY_VARS[0]}"
  OUTPUT_PATH="${APPLY_VARS[1]}"
  GAIN_DB="${APPLY_VARS[2]}"
  LIMIT_LINEAR="${APPLY_VARS[3]}"
  ATTACK_MS="${APPLY_VARS[4]}"
  RELEASE_MS="${APPLY_VARS[5]}"
  OVERWRITE_FLAG="${APPLY_VARS[6]}"
  OUTPUT_SR="${APPLY_VARS[7]}"
  OUTPUT_BIT_DEPTH="${APPLY_VARS[8]}"
  OUTPUT_FORMAT="${APPLY_VARS[9]}"
  METADATA_JSON="${APPLY_VARS[10]}"

  if [[ ! -f "$INPUT_PATH" ]]; then
    python3 -c 'import json,sys; print(json.dumps({"ok": False, "error": f"archivo no existe: {sys.argv[1]}"}, ensure_ascii=False))' "$INPUT_PATH"
    exit 1
  fi

  FF_ARGS=()
  if [[ "$OVERWRITE_FLAG" == "1" ]]; then FF_ARGS+=("-y"); else FF_ARGS+=("-n"); fi
  FF_ARGS+=("-hide_banner" "-nostdin" "-i" "$INPUT_PATH")
  FF_ARGS+=("-af" "volume=${GAIN_DB}dB,alimiter=limit=${LIMIT_LINEAR}:attack=${ATTACK_MS}:release=${RELEASE_MS}:level=false:latency=true")

  if [[ -n "$OUTPUT_SR" ]]; then
    FF_ARGS+=("-ar" "$OUTPUT_SR")
  fi
  case "$OUTPUT_FORMAT" in
    wav)
      if [[ "$OUTPUT_BIT_DEPTH" == "24" ]]; then FF_ARGS+=("-c:a" "pcm_s24le"); fi
      if [[ "$OUTPUT_BIT_DEPTH" == "16" ]]; then FF_ARGS+=("-c:a" "pcm_s16le"); fi
      ;;
    aiff|aif)
      if [[ "$OUTPUT_BIT_DEPTH" == "24" ]]; then FF_ARGS+=("-c:a" "pcm_s24be"); fi
      if [[ "$OUTPUT_BIT_DEPTH" == "16" ]]; then FF_ARGS+=("-c:a" "pcm_s16be"); fi
      ;;
    flac)
      FF_ARGS+=("-c:a" "flac")
      if [[ "$OUTPUT_BIT_DEPTH" == "16" ]]; then FF_ARGS+=("-sample_fmt" "s16"); fi
      if [[ "$OUTPUT_BIT_DEPTH" == "24" ]]; then FF_ARGS+=("-sample_fmt" "s32"); fi
      ;;
    m4a)
      FF_ARGS+=("-c:a" "aac" "-b:a" "256k")
      ;;
    mp3)
      FF_ARGS+=("-c:a" "libmp3lame" "-b:a" "320k")
      ;;
  esac

  while IFS= read -r meta_line; do
    FF_ARGS+=("-metadata" "$meta_line")
  done < <(python3 - <<'PY' "$METADATA_JSON"
import json,sys
m=json.loads(sys.argv[1]) if sys.argv[1].strip() else {}
for k,v in (m.items() if isinstance(m,dict) else []):
    if v is None: 
        continue
    s=str(v)
    if s:
        print(f"{k}={s}")
PY
)

  FF_ARGS+=("$OUTPUT_PATH")
  APPLY_STATUS=0
  APPLY_OUT="$(SPASM_BIN="$SPASM_BIN" "$FFMPEG_BIN" "${FF_ARGS[@]}" 2>&1)" || APPLY_STATUS=$?
  if [[ "$APPLY_STATUS" -ne 0 ]]; then
    python3 - <<'PY' "$APPLY_OUT"
import json,sys
print(json.dumps({"ok": False, "error": "ffmpeg falló en apply_output_gain", "raw": sys.argv[1][-2000:]}, ensure_ascii=False))
PY
    exit "$APPLY_STATUS"
  fi
  python3 - <<'PY' "$APPLY_OUT"
import json,sys
print(json.dumps({"ok": True, "result": sys.argv[1]}, ensure_ascii=False))
PY
  exit $?
fi

